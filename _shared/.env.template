# =============================================================================
# INFRA-STACK — GLOBAL ENVIRONMENT VARIABLES
# Single Source of Truth untuk seluruh infrastruktur
#
# INSTRUKSI:
#   1. UBAH semua nilai CHANGE-ME yang harus di sesuaikan
#   2. Jalankan: make init
#   3. File .env (hasil render) TIDAK PERNAH di-commit ke git
#
# Untuk migrasi ke VM/environment baru:
#   Hanya edit file ini, lalu jalankan make init
# =============================================================================

# -----------------------------------------------------------------------------
# INFRASTRUCTURE IDENTITY
# -----------------------------------------------------------------------------
BASE_DOMAIN=dts.system
HOST_IP=CHANGE-ME
TZ=Asia/Jakarta
INFRA_DNS_SERVER=CHANGE-ME

# -----------------------------------------------------------------------------
# TRAEFIK — Reverse Proxy & TLS Termination
# Dashboard: https://traefik.${BASE_DOMAIN}
# -----------------------------------------------------------------------------
TRAEFIK_ADMIN_USER=admin
TRAEFIK_ADMIN_PASSWORD=CHANGE-ME
TRAEFIK_MEM_LIMIT=256m
TRAEFIK_CPUS=0.5

# -----------------------------------------------------------------------------
# STEP-CA — Internal PKI Certificate Authority
# CA API: https://ca.${BASE_DOMAIN}
# STEPCA_DNS: list SAN untuk CA server cert (digunakan oleh Traefik ACME)
# Nilai menggunakan ${BASE_DOMAIN} yang sudah didefinisikan di atas
# -----------------------------------------------------------------------------
STEPCA_NAME=DTS-Infrastructure-CA
STEPCA_DNS=resolute-ca.${BASE_DOMAIN},step-ca,localhost
STEPCA_ADDRESS=:9000
STEPCA_PROVISIONER=infra-admin
STEPCA_MEM_LIMIT=128m
STEPCA_CPUS=0.25

# -----------------------------------------------------------------------------
# VAULT — Secret Management
# UI: https://resolute-vault.${BASE_DOMAIN}
# -----------------------------------------------------------------------------
VAULT_MEM_LIMIT=512m
VAULT_CPUS=0.5

# -----------------------------------------------------------------------------
# POSTGRESQL — Database Server
# Internal only — tidak di-expose ke host/proxy
# POSTGRES_USER: nama superuser PostgreSQL (bukan POSTGRES_ROOT_USER)
# PGDATA akan di-set ke subdirectory untuk menghindari lost+found issue
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE-ME
POSTGRES_DB=postgres
# Dedicated user & database untuk GitLab
GITLAB_DB_USER=gitlab
GITLAB_DB_PASSWORD=CHANGE-ME
GITLAB_DB_NAME=gitlabdb
POSTGRESQL_MEM_LIMIT=2g
POSTGRESQL_CPUS=1.0

# -----------------------------------------------------------------------------
# MYSQL — Database Server
# Internal only — tidak di-expose ke host/proxy
# -----------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=CHANGE-ME
MYSQL_MEM_LIMIT=1g
MYSQL_CPUS=0.5

# -----------------------------------------------------------------------------
# SEAWEEDFS — S3-Compatible Object Storage
# S3 endpoint: https://resolute-s3.${BASE_DOMAIN}
# ACCESS_KEY: minimal 16 karakter alphanum
# SECRET_KEY: minimal 32 karakter alphanum
# Tentukan sendiri — nilai ini perlu Anda ketahui untuk akses dari project/laptop
# -----------------------------------------------------------------------------
SEAWEEDFS_S3_ACCESS_KEY=CHANGE-ME-16-CHAR-ALPHANUM
SEAWEEDFS_S3_SECRET_KEY=CHANGE-ME-32-CHAR-ALPHANUM
SEAWEEDFS_MEM_LIMIT=1g
SEAWEEDFS_CPUS=0.5

# -----------------------------------------------------------------------------
# POSTFIX — SMTP Relay via Gmail
# Internal only — single mail gateway untuk seluruh stack
# GMAIL_APP_PASSWORD: buat di Google Account → Security → App Passwords (16 char)
# POSTFIX_MYNETWORKS: subnet Docker infra-backend-net
# PENTING: Jika subnet infra-backend-net (172.20.1.0/24) diubah di Section 3,
#          nilai POSTFIX_MYNETWORKS WAJIB diperbarui bersamaan
# -----------------------------------------------------------------------------
GMAIL_USER=akun@gmail.com
GMAIL_APP_PASSWORD=CHANGE-ME
POSTFIX_MYNETWORKS=127.0.0.0/8,172.20.1.0/24
POSTFIX_MEM_LIMIT=256m
POSTFIX_CPUS=0.25
ALLOWED_SENDER_DOMAINS=${BASE_DOMAIN}

# -----------------------------------------------------------------------------
# GITLAB CE — SCM Server
# Web: https://resolute-gitlab.${BASE_DOMAIN}
# Registry: https://resolute-registry.${BASE_DOMAIN}
# SSH: ssh://git@${HOST_IP}:${GITLAB_SSH_PORT}
# GITLAB_ROOT_PASSWORD: minimal 8 karakter (GitLab requirement)
# GITLAB_SSH_PORT: 2222 (port 22 di host dipakai SSH VM)
# -----------------------------------------------------------------------------
GITLAB_ROOT_PASSWORD=CHANGE-ME-8-CHAR-ALPHANUM
GITLAB_SSH_PORT=2222
GITLAB_MEM_LIMIT=6g
GITLAB_CPUS=2.0

# -----------------------------------------------------------------------------
# GITLAB RUNNER — CI/CD Executor
# Internal only — Docker executor via Docker socket
# -----------------------------------------------------------------------------
RUNNER_MEM_LIMIT=2g
RUNNER_CPUS=1.5
