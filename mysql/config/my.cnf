# =============================================================================
# my.cnf — Custom MySQL Configuration
# Di-mount ke: /etc/mysql/conf.d/custom.cnf
# Compatible: MySQL 9.x
# =============================================================================

[mysqld]
container_aware=ON

# Character set
character-set-server  = utf8mb4
collation-server      = utf8mb4_unicode_ci

# Connection
max_connections       = 100
wait_timeout          = 600
interactive_timeout   = 600

# InnoDB tuning (disesuaikan dengan mem_limit 1g)
innodb_buffer_pool_size  = 256M

# N04 FIX: innodb_log_file_size DIHAPUS — deprecated dan removed di MySQL 9.x
# Ganti dengan innodb_redo_log_capacity (MySQL 8.0.30+ dan 9.x)
# Nilai = total redo log capacity (bukan per-file size)
innodb_redo_log_capacity = 134217728

innodb_flush_log_at_trx_commit = 2

# Slow query log
slow_query_log       = 1
slow_query_log_file  = /var/lib/mysql/slow.log
long_query_time      = 2

[client]
default-character-set = utf8mb4
